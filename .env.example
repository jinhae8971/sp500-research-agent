# === Required ===
ANTHROPIC_API_KEY=sk-ant-...
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# Public dashboard URL shown in Telegram messages
DASHBOARD_URL=https://<your-username>.github.io/sp500-research-agent/

# === Tuning ===
CLAUDE_MODEL=claude-sonnet-4-6
TOP_K_GAINERS=5
# Minimum daily trading volume in USD
MIN_VOLUME_USD=10000000
# How many past trading days to compare (default 2)
LOOKBACK_TRADING_DAYS=2
NARRATIVE_LOOKBACK_DAYS=7
